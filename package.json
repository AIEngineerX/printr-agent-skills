    "bs58": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "pg-mem": "^3.0.0",
    "prettier": "^3.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "uuid": "^14.0.0"
  },
  "repository": {
    "type": "git",
