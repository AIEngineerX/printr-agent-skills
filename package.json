{
  "name": "@printr/agent-skills",
  "version": "0.1.0",
  "description": "Claude Code skills + reference implementation for building tokenized-agent revenue loops on Printr POB tokens",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./swap": "./src/swap/index.ts",
    "./payments": "./src/payments/index.ts",
    "./tokenized-agent": "./src/tokenized-agent/index.ts"
  },
  "scripts": {
