* text=auto eol=lf

*.md        text eol=lf
*.ts        text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Lockfiles — always LF, never auto-normalize
package-lock.json  text eol=lf

# Binary / generated — never touch
*.png      binary
*.jpg      binary
*.ico      binary
dist/**    linguist-generated=true
